# Copy to .env.local
# Optional — chat and LLM wiki synthesis work without keys (extractive / graph-only mode).

# Preferred cloud path: OpenRouter (OpenAI-compatible)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional model overrides (defaults: openai/gpt-4o-mini and openai/text-embedding-3-small)
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Fallback if OpenRouter is not set
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Shared aliases (used when provider-specific model env vars are unset)
# LLM_MODEL=
# LLM_EMBEDDING_MODEL=

# Persistent vector store (default: data/vectors.sqlite via better-sqlite3)
# PRESENCE_VECTOR_DB=./data/vectors.sqlite
# PRESENCE_VECTOR_STORE=sqlite
# Legacy fallbacks (still read if PRESENCE_* unset):
# PERSONA_VECTOR_DB=./data/vectors.sqlite
# PERSONA_VECTOR_STORE=sqlite
#
# Optional Postgres + pgvector (install `pg`, enable CREATE EXTENSION vector):
# DATABASE_URL=postgres://user:pass@host:5432/db
# PRESENCE_VECTOR_STORE=pgvector
# PERSONA_VECTOR_STORE=pgvector

# Optional production lock for admin/wiki write endpoints
PRESENCE_ADMIN_TOKEN=
# PERSONA_ADMIN_TOKEN=
